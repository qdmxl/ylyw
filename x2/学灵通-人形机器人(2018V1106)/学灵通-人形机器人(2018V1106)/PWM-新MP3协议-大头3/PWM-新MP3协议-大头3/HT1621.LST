  87          //*******************************************************************
  88          //*********************** IR Remote Module **************************
  89          
  90          //*********************** IR Remote Module **************************
  91          //this programme is used for Receive IR Remote (HT6121).
  92          
  93          //data format: Synchro,AddressH,AddressL,data,/data, (total 32 bit).
  94          
  95          //send a frame(85ms), pause 23ms, send synchro of another frame, pause 94ms
  96          
  97          //data rate: 108ms/Frame
  98          
  99          
 100          //Synchro:low=9ms,high=4.5/2.25ms,low=0.5626ms
 101          //Bit0:high=0.5626ms,low=0.5626ms
 102          //Bit1:high=1.6879ms,low=0.5626ms
 103          //frame space = 23 ms or 96 ms
 104          
 105          /******************** 红外采样时间宏定义, 用户不要随意修改      *******************/
 106          
 107          #if ((D_TIMER0 <= 250) && (D_TIMER0 >= 60))
 108                  #define D_IR_sample                     D_TIMER0                //定义采样时间，在60us~250us之间
 109          #endif
 110          
 111          #define D_IR_SYNC_MAX           (15000/D_IR_sample)     //SYNC max time
 112          #define D_IR_SYNC_MIN           (9700 /D_IR_sample)     //SYNC min time
 113          #define D_IR_SYNC_DIVIDE        (12375/D_IR_sample)     //decide data 0 or 1
 114          #define D_IR_DATA_MAX           (3000 /D_IR_sample)     //data max time
 115          #define D_IR_DATA_MIN           (600  /D_IR_sample)     //data min time
 116          #define D_IR_DATA_DIVIDE        (1687 /D_IR_sample)     //decide data 0 or 1
 117          #define D_IR_BIT_NUMBER         32                                      //bit number
C51 COMPILER V8.05a   HT1621                                                               09/09/2017 11:44:40 PAGE 3   

