 179          /**************** Timer初始化函数 ******************************/
C51 COMPILER V8.05a   HT1621                                                               09/09/2017 11:44:40 PAGE 4   

 180          void Inf_Init(void)
 181          {
 182   1              P32 = 1;
 183   1              TMOD &= 0x0F;           //for STC15Fxxx系列     Timer0 as 16bit reload timer.
 184   1              TH1 = Timer0_Reload / 256;
 185   1              TL1 = Timer0_Reload % 256;
 186   1              TF1 = 0;
 187   1              ET1 = 1;
 188   1              TR1 = 0;
 189   1      
 190   1              IT0  = 1;  //INT0的处罚方式为下降沿触发
 191   1              EX0  = 0;
 192   1              
 193   1              //EA  = 1;
 194   1      }
 195          
 196          //====================================================
 197          void INT0_Interrupt(void) interrupt 0
 198          {
 199   1              EX0  = 0;
 200   1              TH1 = Timer0_Reload / 256;
 201   1              TL1 = Timer0_Reload % 256;      
 202   1              IR_SampleCnt = 0;
 203   1              P_IR_RX_temp = 0;
 204   1              TR1 = 1;
 205   1      }
