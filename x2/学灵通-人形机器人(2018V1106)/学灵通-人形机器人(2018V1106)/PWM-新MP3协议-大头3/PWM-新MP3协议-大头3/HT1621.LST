   6          /*******************    功能说明        **********************************
   7          红外接收程序。适用于市场上用量最大的HT6121/6122及其兼容IC的编码。
   8          
   9          对于用户码与User_code定义不同的遥控器，程序会将用户码一起从串口输出。
  10          
  11          使用模拟串口发送监控显示编码，显示内容为ASCII码和中文。
  12          
  13          本接收程序基于状态机的方式，占用CPU的时间非常少。
  14          ****************************************************************/
  15          
  16          #include "REG15W4Kxx.h"
  17          
  18          /*************  用户系统配置    **************/
  19          #define MAIN_Fosc               11059200L        //定义主时钟, 模拟串口和红外接收会自动适应。5~36MHZ
  20          
  21          #define D_TIMER0                125                        //选择定时器时间, us, 红外接收要求在60us~250us之间
  22          
  23          #define User_code               0x807F           //定义红外接收用户码
  24          
  25          
  26          /*************  以下宏定义用户请勿修改  **************/
  27          #define uchar   unsigned char
  28          #define uint    unsigned int
  29          
  30          #define freq_base                         (MAIN_Fosc / 1200)
  31          #define Timer0_Reload           (65536 - (D_TIMER0 * freq_base / 10000))
  32          
  33          sbit    P_IR_RX = P3^2;         //定义红外接收输入端口
  34          
  35          bit             P_IR_RX_temp;           //Last sample
  36          bit             B_IR_Sync;                      //已收到同步标志
  37          uchar   IR_SampleCnt;           //采样计数
  38          uchar   IR_BitCnt;                      //编码位数
  39          uchar   IR_UserH;                         //用户码(地址)高字节
  40          uchar   IR_UserL;                         //用户码(地址)低字节
  41          uchar   IR_data;                          //数据原码
  42          uchar   IR_DataShit;            //数据反码
  43          
  44          bit             B_IrUserErr;            //User code error flag
  45          bit             B_IR_Press;                     //Key press flag,include repeat key.
  46          uchar   IR_code;                          //IR code     红外键码
  47          uchar   SampleTime;
