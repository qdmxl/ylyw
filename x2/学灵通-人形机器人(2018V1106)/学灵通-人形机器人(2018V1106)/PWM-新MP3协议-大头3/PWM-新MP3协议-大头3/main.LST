 149          void Online_DoInit(void)
 150          { 
 151   1              u8 xdata SrcName[10];                   // 原文件名缓冲区
 152   1              UART1_PrintByte(0xFC);          //联机成功后等待3s，必须等
 153   1              delay1s(1);
 154   1              UART1_PrintByte(0xFE);    //发送初始位置前置码
 155   1              delay1s(1);     
 156   1              strcpy(SrcName, "/SHR0/0");  // 源文件名
 157   1              if(ReadSdcardFile32Bytes(SrcName) == USB_INT_SUCCESS)
 158   1              {
